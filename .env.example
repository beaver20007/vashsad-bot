# ВашСад Бот — переменные окружения
# Скопируй этот файл в .env и заполни значения

# ── Обязательные ─────────────────────────────────────────────
# Токен бота от @BotFather в Telegram
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAA-xxxxxxxxxxxxxxxxxxxxx

# Твой Telegram ID (узнать: написать @userinfobot)
DESIGNER_TELEGRAM_ID=123456789

# API ключ Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx

# ── Персонализация ───────────────────────────────────────────
DESIGNER_NAME=Имя Фамилия

# ── Лимиты Free-тира ────────────────────────────────────────
FREE_CHAT_LIMIT=10
FREE_PHOTO_LIMIT=3
FREE_PLANTS_LIMIT=3

# ── Подписка ────────────────────────────────────────────────
SUBSCRIPTION_PRICE=299

# ── Платежи YooKassa (заполнить позже) ──────────────────────
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
